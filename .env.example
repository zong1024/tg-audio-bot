# Telegram Bot Token（从 @BotFather 获取）
BOT_TOKEN=your_bot_token_here

# NAS 挂载路径（根据你的 NAS 修改）
# 绿联 DXP2800: 通过 Docker 卷或 /volume1/xxx
NAS_PATH=/tmp/music

# 音频格式：flac（无损） / aac（原始） / best（不转码）
AUDIO_FORMAT=flac

# 代理服务器（YouTube/Telegram 需要翻墙）
PROXY_HOST=192.168.0.103
PROXY_HTTP_PORT=1081
PROXY_SOCKS_PORT=1080

# 可选：限定用户 ID（逗号分隔），留空 = 所有人可用
# ALLOWED_USERS=123456789

# 可选：B站 Cookies 文件路径
# BILIBILI_COOKIES=./cookies.txt
